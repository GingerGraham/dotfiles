[Unit]
Description=AI Config GitOps Sync
Documentation=https://github.com/{{ ansible_facts['env']['USER'] }}/dotfiles
After=network-online.target
Wants=network-online.target
ConditionPathExists={{ ai_sync_conf_path }}

[Service]
Type=oneshot
ExecStart={{ ai_sync_script_dest }}

StandardOutput=journal
StandardError=journal

# Don't hammer the remote if git or SSH is broken
Restart=no
