# {{ ai_sync_conf_path }}
# Generated by dotfiles ai-tools role on {{ ansible_facts['date_time']['date'] }}.
# This file is never overwritten by Ansible — edit it directly to change
# runtime behaviour. The ai-config-sync timer reads it on every run.

# Upstream repo URL (used by ai-config-sync to fetch updates).
REPO_URL="{{ _ai_effective_repo_url }}"

# Branch to track. Change this to test a feature branch; switch back to
# resume normal sync.
GIT_BRANCH="{{ ai_config_branch }}"

# Local path where the ai-config repo is cloned.
AI_CONFIG_CLONE_DIR="{{ ai_config_clone_dir }}"

# Set DEV_MODE=true to suspend automatic sync while actively editing config
# on this machine. The timer continues to run but exits early. Reset to false
# once your changes are pushed upstream.
DEV_MODE="false"
