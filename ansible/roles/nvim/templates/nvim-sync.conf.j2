# {{ nvim_sync_conf_path }}
# Generated by dotfiles nvim role on {{ ansible_date_time.date }}.
# This file is never overwritten by Ansible — edit it directly to change
# runtime behaviour. The nvim-config-sync timer reads it on every run.

# Upstream repo URL (used by nvim-config-sync to fetch updates).
REPO_URL="{{ _nvim_effective_repo_url }}"

# Branch to track. Change this to test a feature branch; switch back to
# resume normal sync. The 'nvim-config-branch' script (if deployed) manages
# this value for you.
GIT_BRANCH="{{ nvim_config_branch }}"

# Local path to the neovim config directory.
NVIM_CONFIG_DIR="{{ nvim_config_dir }}"

# Set DEV_MODE=true to suspend automatic sync while actively editing this
# config. The timer continues to run but exits early when DEV_MODE is active.
# Reset to false when your changes are pushed upstream.
DEV_MODE="false"
