# Generated by Ansible from host_vars — do not edit directly.
# To add a project:    git-add-project <context> <provider> <email>
# To update a project: git-update-project <context> <provider> --email <email>
# To rebuild manually: ansible-playbook site.yml --tags git
{% set base = projects_base | replace('~', ansible_env.HOME) %}
{% for project in git_projects %}
[includeIf "gitdir:{{ base }}/{{ project.context }}/{{ project.provider }}/"]
    path = ~/.config/git/profiles/{{ (project.context + '-' + project.provider) | lower | replace(' ', '-') }}.inc

{% endfor %}
