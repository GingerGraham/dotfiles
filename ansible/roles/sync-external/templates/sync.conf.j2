# {{ external_sync_conf_dir }}/{{ repo.name }}/sync.conf
# Generated by dotfiles sync-external role on {{ now(fmt='%Y-%m-%d') }}.
# This file is never overwritten by Ansible after creation — edit it directly
# to change runtime behaviour. The external-sync timer reads it on every run.

# Upstream repo URL — informational; git already knows its own remote.
REPO_URL="{{ _effective_repo_url }}"

# Branch to track. Defaults to this repo's .dotfiles-sync.yml 'branch' field
# (or 'main' if it has no manifest). Change this to test a feature branch;
# switch back to resume normal tracking. Ansible will not overwrite this
# value on subsequent runs.
GIT_BRANCH="{{ _effective_branch }}"

# Local path to the cloned repo.
CLONE_DIR="{{ _clone_dir_absolute }}"

# Set DEV_MODE=true to suspend automatic sync for this repo only — other
# registered repos keep syncing on schedule. Reset to false to resume.
DEV_MODE="false"
