# ansible/host_vars/localhost.yml.example
#
# Copy this file to localhost.yml and populate before running Ansible.
#
#   cp localhost.yml.example localhost.yml
#
# localhost.yml is gitignored — your personal config never enters the repo.
# Running install.sh will also generate this file interactively.

# ── Profile ───────────────────────────────────────────────────────────────────
# Controls which roles run on this machine.
dotfiles_profile: workstation    # workstation | server | minimal

# ── Machine ───────────────────────────────────────────────────────────────────
machine_name: ""                 # Friendly name used in git config and prompt.
                                 # Defaults to system hostname if left empty.

# ── Companion repos ───────────────────────────────────────────────────────────
# SSH URLs for private companion repos. Leave empty to skip cloning.
# Roles that depend on these will no-op cleanly when empty.
nvim_config_repo_url: ""         # e.g. git@github.com:you/nvim-config.git
ai_config_repo_url:   ""         # e.g. git@github.com:you/ai-config.git

# ── Git: global identity ──────────────────────────────────────────────────────
# Used as the default when no project-specific profile matches the working directory.
git_name:                Your Name
git_default_email:        you@example.com
# git_default_signing_key: GPGFINGERPRINT   # optional — enables global gpgsign

# Git tool preferences
git_editor:    vim                # or: code --wait, nano, etc.
git_diff_tool: vimdiff            # or: code
git_merge_tool: vimdiff           # or: code

# ── Git: projects ─────────────────────────────────────────────────────────────
# Root directory for all context/provider project trees.
projects_base: ~/Projects

# Each entry creates:
#   - A directory:  <projects_base>/<context>/<provider>/
#   - A profile:    ~/.config/git/profiles/<context>-<provider>.inc
#   - An includeIf: in ~/.config/git/project-includes
#
# Fields:
#   context      Life/work area — Personal, Acme, ClientName, etc.
#   provider     Git host under that context — GitHub, GitLab, Bitbucket, AzureDevOps, etc.
#   email        Identity for repos under this context/provider
#   signing_key  Optional GPG fingerprint — enables gpgsign for this context
#   ssh_key      Optional SSH key path — informational, consumed by the ssh role
#   name         Optional display name override — defaults to git_name
#
git_projects:
  - context: Personal
    provider: GitHub
    email: you@example.com
    signing_key: GPGFINGERPRINT

  - context: Personal
    provider: GitLab
    email: you@example.com

  - context: Personal
    provider: Bitbucket
    email: you@example.com

  - context: WorkContext
    provider: AzureDevOps
    email: you@work-domain.com
    ssh_key: ~/.ssh/id_ed25519_work

# ── SSH ───────────────────────────────────────────────────────────────────────
# Git forges to pre-trust in ~/.ssh/known_hosts.
# ssh_known_hosts_forges:
#   - github.com
#   - gitlab.com
#   - bitbucket.org
#   - git.internal.example.com
