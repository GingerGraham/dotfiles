# Copy this file to localhost.yml and fill in your values, or run install.sh
# (coming soon) to generate it interactively.
# This file is gitignored — never commit localhost.yml.

# Role profile to activate on this machine.
# Valid values: workstation | server | minimal
dotfiles_profile: workstation

# Friendly machine name used in git config and prompt.
# Defaults to system hostname if left empty.
machine_name: ""

# Git identity — used by the git role to write per-context profile includes.
git_personal_email: ""
git_work_email: ""

# SSH URLs for companion repos. Leave empty to skip cloning.
# Roles that depend on these will no-op cleanly when empty.
nvim_config_repo_url: ""   # e.g. git@github.com:you/nvim-config.git
ai_config_repo_url: ""     # e.g. git@github.com:you/ai-config.git
