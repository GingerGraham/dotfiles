# ansible/host_vars/localhost.yml.example
#
# Copy this file to localhost.yml and populate before running Ansible.
#
#   cp localhost.yml.example localhost.yml
#
# localhost.yml is gitignored — your personal config never enters the repo.
# Running install.sh will also generate this file interactively.

# ── Profile ───────────────────────────────────────────────────────────────────
# Controls which roles run on this machine.
dotfiles_profile: workstation    # workstation | server | minimal

# ── Machine ───────────────────────────────────────────────────────────────────
machine_name: ""                 # Friendly name used in git config and prompt.
                                 # Defaults to system hostname if left empty.

# ── Role feature flags ────────────────────────────────────────────────────────
# Fine-grained control within a profile. Defaults are set in group_vars/all.yml
# and reflect sensible behaviour for the chosen profile. Override here to opt
# out of a specific role without changing your profile.
#
# common is always required and cannot be disabled.
#
dotfiles_sync_enabled: true  # Gates roles/sync (dotfiles self-sync) and roles/sync-external.
                             # systemd user timer (Linux) or launchd agent (macOS).

# ── Extra roles ───────────────────────────────────────────────────────────────
# Optional roles that are not part of any profile. Each entry must correspond
# to a role directory under ansible/roles/. Roles are responsible for their
# own platform/distro guards internally.
#
# These run for all profiles — add your own when: guards inside the role if
# you need to restrict to a specific profile.
#
# Example:
#   dotfiles_extra_roles:
#     - clamav
#     - 1password
#
dotfiles_extra_roles: []

# ── External add-on repos ───────────────────────────────────────────────────────
# Repos synced/deployed by roles/sync-external. Not applicable to the
# 'minimal' profile. install.sh collects these interactively; add more later
# by editing this list directly (see docs/external-sync.md#adding-a-repo).
#
# Fields:
#   name       Unique — used for the config/state directory, the SSH alias
#              (private repos only), and as the sync-script argument.
#              Lowercase letters, digits, and hyphens only.
#   repo_url   HTTPS/SSH URL, any git host, for public repos. For private
#              repos, it's rewritten to the repo's own SSH alias
#              automatically at Ansible run time — you never need to
#              hand-edit this to an alias form yourself.
#   clone_dir  Where the repo is cloned. May use ~.
#   private    true | false — controls the URL rewrite and whether a deploy
#              key is expected (see docs/external-sync.md for the deploy-key
#              walkthrough).
#
# What each repo actually deploys (if anything) is described by its own
# .dotfiles-sync.yml manifest at its repo root — see
# docs/sync-manifest-spec.md. This file only says *which* repos to sync,
# never *what* they contain.
#
external_synced_repos:
  - name: nvim-config
    repo_url: "https://github.com/you/nvim-config.git"
    clone_dir: "~/.config/nvim"
    private: false

  - name: ai-config
    repo_url: "https://github.com/you/ai-config.git"
    clone_dir: "~/.local/share/ai-config"
    private: true

# ── Git: global identity ──────────────────────────────────────────────────────
# Used as the default when no project-specific profile matches the working directory.
git_name:          Your Name
git_default_email: you@example.com
# git_default_signing_key: GPGFINGERPRINT   # optional — enables global gpgsign

# Git tool preferences
git_editor:     vim               # or: code --wait, nano, etc.
git_diff_tool:  vimdiff           # or: code
git_merge_tool: vimdiff           # or: code

# ── Git: projects ─────────────────────────────────────────────────────────────
# Root directory for all context/provider project trees.
projects_base: ~/Projects

# Each entry creates:
#   - A directory:  <projects_base>/<context>/<provider>/
#   - A profile:    ~/.config/git/profiles/<context>-<provider>.inc
#   - An includeIf: in ~/.config/git/project-includes
#
# Fields:
#   context      Life/work area — Personal, Acme, ClientName, etc.
#   provider     Git host under that context — GitHub, GitLab, Bitbucket, AzureDevOps, etc.
#   email        Identity for repos under this context/provider
#   signing_key  Optional GPG fingerprint — enables gpgsign for this context
#   ssh_key      Optional SSH key path — informational, consumed by the ssh role
#   name         Optional display name override — defaults to git_name
#
git_projects:
  - context: Personal
    provider: GitHub
    email: you@example.com
    signing_key: GPGFINGERPRINT

  - context: Personal
    provider: GitLab
    email: you@example.com

  - context: Personal
    provider: Bitbucket
    email: you@example.com

  - context: WorkContext
    provider: AzureDevOps
    email: you@work-domain.com
    ssh_key: ~/.ssh/id_ed25519_work

# ── SSH ───────────────────────────────────────────────────────────────────────
# Git forges to pre-trust in ~/.ssh/known_hosts.
# Entries are added idempotently — existing entries are never removed.
#
# known_hosts_entries:
#   - github.com
#   - gitlab.com
#   - bitbucket.org
#   - ssh.dev.azure.com